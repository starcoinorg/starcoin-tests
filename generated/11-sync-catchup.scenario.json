{
  "id": "11-sync-catchup",
  "title": "节点恢复后同步追平",
  "objective": "验证节点长时间离线后恢复，能够在限定时间内重新追平区块高度",
  "scope": {
    "nodes": 4,
    "network": "dev",
    "tls_http": false,
    "tls_ws": false
  },
  "fault": {
    "type": "node_down",
    "selector": "random",
    "params": {
      "duration_seconds": 180,
      "count": 1
    }
  },
  "traffic": {
    "transports": [
      "http",
      "ws"
    ],
    "http_qps": 60,
    "ws_subscriptions": 80
  },
  "duration": "20m",
  "thresholds": [
    {
      "metric": "chain_progress",
      "op": "==",
      "value": true
    },
    {
      "metric": "rpc_success_rate",
      "op": ">=",
      "value": 99.0
    },
    {
      "metric": "peer_recovery_seconds",
      "op": "<=",
      "value": 180
    },
    {
      "metric": "peer_count_after_recovery",
      "op": ">=",
      "value": 2
    },
    {
      "metric": "sync_recovery_seconds",
      "op": "<=",
      "value": 300
    }
  ],
  "observe": [
    "height",
    "peer_count",
    "sync_lag",
    "sync_recovery_seconds",
    "rpc_success_rate",
    "rpc_p95_ms",
    "rpc_p99_ms"
  ],
  "schema_version": "v1"
}
